model User {
  id               String           @id
  name             String
  email            String
  emailVerified    Boolean          @default(false)
  image            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  twoFactorEnabled Boolean?         @default(false)
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  visitedCountries VisitedCountry[]

  @@unique([email])
  @@map("user")
}
